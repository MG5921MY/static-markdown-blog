# ========================================
# 站点配置文件示例
# ========================================

# ---------- 站点基本信息 ----------
site:
  name: YourSiteName
  alias: 站点别名
  description: 个人博客 · 学习笔记 · 生活记录
  author: YourName
  email: your-email@example.com
  # 网站图标（相对于站点根目录）
  favicon: assets-example/favicon.ico
  # 网站 Logo（相对于站点根目录）
  logo: assets-example/favicon.ico

# ---------- 主题配置 ----------
# 主题目录固定为 usr/themes/
# 只需填写主题文件夹名称
theme:
  # 当前使用的主题（对应 usr/themes/ 下的目录名）
  active: default
  # 主题配置（可被主题读取）
  config:
    # 主色调
    primaryColor: "#6366f1"
    # 是否显示页脚
    showFooter: true

# ---------- 备案信息 ----------
beian:
  # 是否显示备案信息
  enabled: false
  # 网站对外显示名称
  displayName: YourSiteName
  # 别名
  aliasName: 站点别名
  # 备案网站名
  recordName: YourSiteName
  # ICP 备案
  icp:
    enabled: false
    number: "备案号-XXXXXXXXX"
    url: "https://beian.miit.gov.cn/"
  # 公安备案
  police:
    enabled: true
    # 备案中显示的文字，备案成功后改为空并填写 number 和 url
    statusText: "备案中（备案成功后填写）"
    number: ""
    url: ""
  # 版权年份
  year: 2025

# ---------- 文章扫描配置 ----------
scan:
  # 最大递归深度（0=当前目录，-1=无限）
  maxDepth: 20
  # 排除规则
  exclude:
    - "_*"
    - "draft/*"
    - "README.md"

# ---------- 文章分类目录 ----------
# type: flat (平铺模式 - 所有文章直接展示)
# type: tree (层级模式 - 按子目录分组展示)
categories:
  - id: guide
    name: 使用指南
    icon: 📖
    path: posts-example/guide
    description: 项目介绍与使用教程
    type: tree

  - id: features
    name: 功能展示
    icon: ✨
    path: posts-example/features
    description: 博客系统功能特性介绍
    type: flat

  - id: demo
    name: 示例文章
    icon: 📝
    path: posts-example/demo
    description: Markdown 写作示例
    type: flat

# ---------- 导航菜单 ----------
# 导航菜单由 pages 自动生成，也可手动添加外部链接
nav:
  - name: 首页
    url: ./index.html
  - name: 使用指南
    url: ./page.html?id=guide
  - name: 功能展示
    url: ./page.html?id=features
  - name: 关于
    url: ./page.html?id=about

# ---------- 自定义页面 ----------
# 页面类型:
#   - type: markdown  绑定单个 md 文件
#   - type: category  绑定文章分类（显示该分类的文章列表）
#
# 通用属性:
#   - id: 页面唯一标识（用于 URL: page.html?id=xxx）
#   - name: 页面名称
#   - icon: 图标（可选）
#   - description: 页面描述（可选）
pages:
  - id: about
    name: 关于本站
    icon: 👤
    type: markdown
    source: pages-example/about.md

  - id: guide
    name: 使用指南
    icon: 📖
    type: category
    categoryId: guide

  - id: features
    name: 功能展示
    icon: ✨
    type: category
    categoryId: features

# ---------- 显示配置 ----------
display:
  # 首页每页显示文章数
  postsPerPage: 10
  # 摘要最大长度
  summaryLength: 150
  # Hero 区域徽章文字（留空则不显示）
  heroBadge: ""
  # Hero 区域副标题（支持 \n 换行）
  heroSubtitle: "记录思考，沉淀经验"
  # 是否显示站点信息区域
  showSiteInfo: true
  # 站点类型
  siteType: "个人博客"
  # 内容方向
  contentDirection: "技术 / 工具 / 随记"
