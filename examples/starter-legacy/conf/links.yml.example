# ============================================
# 友情链接配置
# 
# 在 config.yml 中启用：
#   features:
#     links:
#       enabled: true
#       source: conf/links.yml
# 
# 在导航栏添加入口：
#   nav:
#     - name: 友链
#       url: ./links.html
# ============================================

# 链接分组（可选）
groups:
  - id: friends
    name: 好友博客
    icon: 👥
  - id: tools
    name: 常用工具
    icon: 🔧
  - id: resources
    name: 学习资源
    icon: 📚

# 友情链接列表
links:
  # 示例链接
  - name: GitHub
    url: https://github.com
    icon: 🐙
    description: 全球最大的代码托管平台
    group: tools

  - name: Stack Overflow
    url: https://stackoverflow.com
    icon: 📝
    description: 程序员问答社区
    group: tools

  - name: MDN Web Docs
    url: https://developer.mozilla.org
    icon: 📖
    description: Web 技术权威文档
    group: resources

  # 带头像的链接示例
  # - name: 某某的博客
  #   url: https://example.com
  #   avatar: https://example.com/avatar.png
  #   description: 一个有趣的技术博客
  #   group: friends
